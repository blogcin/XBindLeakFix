<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WinUI3Leak.NormalWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Normal Window (NO LEAK)">

    <Grid Padding="20">
        <StackPanel VerticalAlignment="Center" Spacing="12">
            <TextBlock Text="This window uses traditional event binding." FontSize="16" />
            <TextBlock Text="It WILL be garbage collected after closing." Foreground="Green" FontSize="14" />
            <Button Content="Click Me (Normal)" Click="OnButtonClick" HorizontalAlignment="Center" />
            <TextBlock x:Name="StatusText" FontSize="14" />
        </StackPanel>
    </Grid>
</Window>
